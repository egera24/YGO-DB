# Local development (SQLite default when DATABASE_URL is unset)
ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# Permanent free cloud: Neon Postgres (NOT Render Postgres — Render free DB expires in 30 days)
# Use the POOLED connection string from Neon dashboard (includes -pooler host, sslmode=require)
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# ENV=production

# Render free web service: set the same DATABASE_URL + SECRET_KEY in Render Dashboard
# GitHub Actions: add DATABASE_URL as repository secret for import-catalog workflow

# Optional overrides
# PORT=8000
# YGO_API_URL=https://db.ygoprodeck.com/api/v7/cardinfo.php
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# SEARCH_DEFAULT_LIMIT=200
# SEARCH_MAX_LIMIT=500
