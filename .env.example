# Local development (SQLite default when DATABASE_URL is unset)
ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# Production / Render (set by Render dashboard or locally for Postgres testing)
# DATABASE_URL=postgresql://user:pass@host:5432/ygo
# ENV=production
# PORT=8000

# Optional overrides
# YGO_API_URL=https://db.ygoprodeck.com/api/v7/cardinfo.php
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# SEARCH_DEFAULT_LIMIT=200
# SEARCH_MAX_LIMIT=500
