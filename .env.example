# =============================================================================
# Production-parity local dev (recommended — matches Render + Neon Postgres)
# Copy to .env and fill in your Neon *dev branch* pooled URL (not production).
# Neon Console → Branches → create "dev" → Connection details → pooled string
# =============================================================================
ENV=production
DATABASE_URL=postgresql://user:pass@ep-xxx-dev-pooler.region.aws.neon.tech/neondb?sslmode=require
SECRET_KEY=your-dev-only-secret-not-used-on-render
PORT=8000

# One-time after creating .env:
#   alembic upgrade head
#   python -m ygo_app.jobs.import_catalog
# Daily: python run.py   (add --reload for hot reload)

# =============================================================================
# Lightweight SQLite mode (optional — fast offline, NOT like production)
# Comment out DATABASE_URL above and use:
# =============================================================================
# ENV=development
# SECRET_KEY=change-me-to-a-long-random-string
# (unset DATABASE_URL — app uses data/ygo.db)
#   python -m ygo_app.import_data --from-api

# =============================================================================
# Card image mirror (Cloudflare R2 / any S3-compatible) — optional locally;
# required as GitHub repo secrets for the GHA "images" job + import URL rewrite.
# =============================================================================
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_BUCKET=ygo-card-images
# IMAGE_BASE_URL=https://pub-xxxx.r2.dev

# Render ygo-app (main) + GitHub DATABASE_URL: production Neon URL
# Render ygo-app-dev (develop) + GitHub DATABASE_URL_DEV: dev Neon URL
# Never commit .env
# SEARCH_DEFAULT_LIMIT=200
# SEARCH_MAX_LIMIT=500
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# YGO_API_URL=https://db.ygoprodeck.com/api/v7/cardinfo.php

# Cardmarket local scrape — optional proxy, profile pool, and polite pacing
# CARDMARKET_HTTP_PROXY=http://user:pass@host:port
# CARDMARKET_BROWSER_PROFILES=default,alt1,alt2
# CARDMARKET_DISCOVERY_RPS=0.12
# CARDMARKET_PRICE_RPS=0.2
# CARDMARKET_WORKERS=1
# See docs/cloudflare/README.md for rate-limit recovery after HTTP 429 / Error 1015
