# =============================================================================
# Production-parity local dev (recommended — matches Render + Neon Postgres)
# Copy to .env and fill in your Neon *dev branch* pooled URL (not production).
# Neon Console → Branches → create "dev" → Connection details → pooled string
# =============================================================================
ENV=production
DATABASE_URL=postgresql://user:pass@ep-xxx-dev-pooler.region.aws.neon.tech/neondb?sslmode=require
SECRET_KEY=your-dev-only-secret-not-used-on-render
PORT=8000

# One-time after creating .env:
#   alembic upgrade head
#   python -m ygo_app.jobs.import_catalog
# Daily: python run.py   (add --reload for hot reload)

# =============================================================================
# Lightweight SQLite mode (optional — fast offline, NOT like production)
# Comment out DATABASE_URL above and use:
# =============================================================================
# ENV=development
# SECRET_KEY=change-me-to-a-long-random-string
# (unset DATABASE_URL — app uses data/ygo.db)
#   python -m ygo_app.import_data --from-api

# Render Dashboard + GitHub Actions: use production Neon URL (never commit .env)
# SEARCH_DEFAULT_LIMIT=200
# SEARCH_MAX_LIMIT=500
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# YGO_API_URL=https://db.ygoprodeck.com/api/v7/cardinfo.php
